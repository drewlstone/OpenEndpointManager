# Copy to .env and adjust. In production, source secrets from a secret manager.
ENVIRONMENT=development
SECRET_KEY=change-me-use-a-32+-char-random-secret
POLYPROV_PLANE=all

DATABASE_URL=postgresql+asyncpg://polyprov:polyprov@db:5432/polyprov
DATABASE_URL_SYNC=postgresql+psycopg2://polyprov:polyprov@db:5432/polyprov
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

REDIS_URL=redis://redis:6379/0
CONFIG_CACHE_TTL=3600
CHECKIN_FLUSH_BATCH=500

PROVISIONING_BASE_PATH=/provisioning/
PROVISIONING_ROOT=/data/provisioning_root

S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=polyprov-firmware
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

RATE_LIMIT_PER_MINUTE=30

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme123
