{
  "title": "PolyProv — Provisioning Overview",
  "uid": "polyprov-overview",
  "schemaVersion": 39,
  "tags": ["polyprov"],
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "Provisioning request rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {"expr": "sum(rate(polyprov_provisioning_requests_total[1m])) by (path_type, cache)",
         "legendFormat": "{{path_type}} {{cache}}"}
      ]
    },
    {
      "id": 2,
      "title": "Cache hit ratio",
      "type": "stat",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0},
      "targets": [
        {"expr": "sum(rate(polyprov_cache_hits_total[5m])) / (sum(rate(polyprov_cache_hits_total[5m])) + sum(rate(polyprov_cache_misses_total[5m])))",
         "legendFormat": "hit ratio"}
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1,
        "thresholds": {"steps": [
          {"color": "red", "value": null},
          {"color": "yellow", "value": 0.9},
          {"color": "green", "value": 0.95}]}}}
    },
    {
      "id": 3,
      "title": "Provisioning latency (p50/p95/p99)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(polyprov_provisioning_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, sum(rate(polyprov_provisioning_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p95"},
        {"expr": "histogram_quantile(0.99, sum(rate(polyprov_provisioning_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p99"}
      ]
    },
    {
      "id": 4,
      "title": "Check-in rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 8},
      "targets": [{"expr": "sum(rate(polyprov_checkins_total[1m]))", "legendFormat": "check-ins/s"}]
    },
    {
      "id": 5,
      "title": "Check-in buffer depth (write backlog)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 8},
      "targets": [{"expr": "polyprov_checkin_buffer_depth", "legendFormat": "pending writes"}]
    },
    {
      "id": 6,
      "title": "Config render duration",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(polyprov_config_render_seconds_bucket[5m])) by (le))", "legendFormat": "render p95"}
      ]
    },
    {
      "id": 7,
      "title": "Firmware bytes served",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [{"expr": "sum(rate(polyprov_firmware_bytes_total[5m]))", "legendFormat": "bytes/s"}]
    }
  ]
}
