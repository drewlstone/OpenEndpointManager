# Copy to .env in this directory to override Docker Compose defaults.
# Do not commit real .env files.

# Active Health Engine
HEALTH_PROBE_ICMP_ENABLED=false
HEALTH_PROBE_INTERVAL_SECONDS=900
HEALTH_PROBE_TIMEOUT_SECONDS=2
HEALTH_PROBE_BATCH_SIZE=100
HEALTH_PROBE_CONCURRENCY=25
HEALTH_PROBE_JITTER_SECONDS=300
HEALTH_PROBE_SCHEDULER_ENABLED=true
HEALTH_PROBE_SCHEDULE_SECONDS=60
HEALTH_PROBE_CLAIM_TIMEOUT_SECONDS=300
